# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# DB_ENCRYPTION_SECRET: Required for AES-256-GCM medical records encryption at rest.
# Provide a secure 32-character string.
DB_ENCRYPTION_SECRET="sante-plus-secret-key-32-chars-long!"

# LNBITS_API_KEY: Optional. Testnet or Mainnet invoice key for real Lightning payments.
# Leave blank to run in fully featured local simulation mode.
LNBITS_API_KEY=""

# BLOCKSTREAM_API_URL: Optional. For real testnet Bitcoin transactions queries.
BLOCKSTREAM_API_URL="https://blockstream.info/testnet/api"

